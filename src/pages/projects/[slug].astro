---
import '../../styles/global.css';
import { projects, type Project } from '../../data/projects';

type Props = {
  project: Project;
};

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const base = `${import.meta.env.BASE_URL}/`.replace(/\/+$/, '/');
const asset = (path: string) => `${base}${path}`;
const route = (path = '') => `${base}${path}`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={project.summary} />
    <title>{project.shortTitle} | Rohan Joshi</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cabin:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={asset('favicon.ico')} />
  </head>

  <body>
    <header class="site-nav">
      <a class="nav-brand" href={route()}>RJ</a>
      <nav aria-label="Primary navigation">
        <a href={route('#portfolio')}>Portfolio</a>
        <a href={route('#about')}>About</a>
        <a href={route('#contact')}>Contact</a>
      </nav>
    </header>

    <main>
      <section class="project-hero">
        <div class="project-hero-copy">
          <a class="back-link" href={route('#portfolio')}>Back to portfolio</a>
          <p class="project-category">{project.category}</p>
          <h1>{project.title}</h1>
          <p>{project.summary}</p>
        </div>
        <img src={asset(project.image)} alt={project.imageAlt} />
      </section>

      <section class="project-body">
        <aside class="project-sidebar">
          <span>{project.date}</span>
          {
            project.sourceUrl && (
              <a href={project.sourceUrl} target="_blank" rel="noreferrer">
                Original source
              </a>
            )
          }
        </aside>

        <div class="project-sections">
          {
            project.sections.map((section) => (
              <section class="project-section">
                <h2>{section.heading}</h2>
                {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
                {section.bullets && (
                  <ul>
                    {section.bullets.map((bullet) => <li>{bullet}</li>)}
                  </ul>
                )}
              </section>
            ))
          }
        </div>
      </section>

      <section class="project-gallery" aria-label={`${project.shortTitle} images`}>
        {
          project.gallery.map((image) => (
            <figure>
              <img src={asset(image.src)} alt={image.alt} loading="lazy" />
              {image.caption && <figcaption>{image.caption}</figcaption>}
            </figure>
          ))
        }
      </section>

      <footer class="site-footer" id="contact">
        <span>&copy; 2026 Rohan Joshi</span>
        <div>
          <a href="mailto:rohan.joshi@duke.edu">Email</a>
          <a href="https://github.com/rjoshi4464-rgb">GitHub</a>
          <a href="https://www.linkedin.com/in/rohanjoshi2/">LinkedIn</a>
        </div>
      </footer>
    </main>
  </body>
</html>
