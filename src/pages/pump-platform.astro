---
import '../styles/global.css';

const base = `${import.meta.env.BASE_URL}/`.replace(/\/+$/, '/');
const asset = (path: string) => `${base}${path}`;
const route = (path = '') => `${base}${path}`;

const projectPath = 'projects/pump-platform';
const heroImage = asset(`${projectPath}/hero-fea.png`);

const requirements = [
  {
    label: 'Pump load',
    value: '12.5 lb',
    detail: 'Support the centrifugal pump through its fixed mounting pattern.',
  },
  {
    label: 'Hydraulic target',
    value: '150 GPM',
    detail: 'Deliver flow to a 60 ft head at 65 percent pump efficiency.',
  },
  {
    label: 'Pulley loading',
    value: '10 in',
    detail: 'Account for belt forces, pulley torque, and offset reactions.',
  },
  {
    label: 'Deflection target',
    value: '< 1 mm',
    detail: 'Limit tip displacement during the design sizing phase.',
  },
  {
    label: 'Safety factor',
    value: '>= 1.5',
    detail: 'Meet yield and buckling margins for the critical members.',
  },
  {
    label: 'Height limit',
    value: '< 24 in',
    detail: 'Fit within the available frame and operating envelope.',
  },
  {
    label: 'Assembly',
    value: 'Clevis pins',
    detail: 'Use removable pin connections for modular installation.',
  },
  {
    label: 'Materials',
    value: 'Aluminum',
    detail: 'Use corrosion-resistant standard stock where possible.',
  },
  {
    label: 'Budget',
    value: '< $150',
    detail: 'Keep purchased raw material cost within the project cap.',
  },
];

const approach = [
  {
    title: 'Static equilibrium established the reaction loads.',
    detail:
      'The platform, support arms, wall mounts, belt tensions, and pump weight were modeled with force and moment balance before detailed stress checks.',
  },
  {
    title: 'Pulley forces drove the combined load case.',
    detail:
      'The design accounted for belt tension, pulley torque, and the moment generated by the pump-pulley offset from the frame.',
  },
  {
    title: 'Combined loading governed the platform.',
    detail:
      'Bending, torsion, axial stress, and transverse shear were combined to identify the most demanding stress states.',
  },
  {
    title: 'Stress concentrations were treated explicitly.',
    detail:
      'Through-holes, support-arm pin holes, and platform connections were checked with concentration factors from machine design tables.',
  },
  {
    title: 'Von Mises stress was used for yielding.',
    detail:
      'Multi-axial stress states were reduced to a single failure metric for ductile aluminum components.',
  },
  {
    title: 'Buckling controlled the compression members.',
    detail:
      'Euler buckling was used to confirm that the slender support arms were stable under compressive reaction loads.',
  },
];

const feaRows = [
  ['Support arm', '3289 psi', 'Final mesh von Mises stress for the governing arm region.'],
  ['Platform', '14604 psi', 'Peak platform stress near the top cross section and connections.'],
  ['Pin', '23057 psi', 'Highest localized stress, checked separately against steel pin capacity.'],
  ['Deflection', '2.807 mm', 'SolidWorks prediction compared with the analytical estimate of 2.441 mm.'],
];

const validationRows = [
  ['Recorded weight', '1.8625 lb', 'Measured prototype mass during validation.'],
  ['Recorded height', '14 in', 'Final assembly remained under the 24 in height limit.'],
  ['Recorded load', '115 lbf', 'Full applied validation load on the physical prototype.'],
  ['Recorded deflection', '0.0984 in', 'Equivalent to about 2.5 mm during testing.'],
];

const gallery = [
  {
    src: `${projectPath}/cad-isometric.png`,
    alt: 'Annotated CAD isometric view of the pump support platform assembly',
    caption: 'CAD isometric view showing the platform, support arms, clevis-pin connections, and loading surface.',
  },
  {
    src: `${projectPath}/assembly-drawing.png`,
    alt: 'Assembly drawing for the pump support platform',
    caption: 'Assembly drawing with frame members, support arms, pulley, and bill of materials.',
  },
  {
    src: `${projectPath}/free-body-diagrams.png`,
    alt: 'Free body diagrams used for the initial pump support platform design',
    caption: 'Free-body diagrams used to solve reactions from belt tension, pump weight, and support loads.',
  },
  {
    src: `${projectPath}/python-vm-diagrams.png`,
    alt: 'Python generated shear and moment diagrams for the pump support platform',
    caption: 'Python-generated shear and moment diagrams used in the analytical load path model.',
  },
  {
    src: `${projectPath}/critical-stress-locations.png`,
    alt: 'Critical stress location diagram for the platform holes and beam section',
    caption: 'Diagram identifying platform through-holes and support-arm pin holes as critical stress locations.',
  },
  {
    src: `${projectPath}/applied-loads.png`,
    alt: 'SolidWorks load setup for the pump support platform',
    caption: 'Applied load setup for the SolidWorks model, including belt loads, pump weight, torque, and gravity.',
  },
  {
    src: `${projectPath}/fea-full-structure.png`,
    alt: 'Full structure von Mises stress contour plot',
    caption: 'Full-structure von Mises contour plot used to check global stress behavior.',
  },
  {
    src: `${projectPath}/fea-support-arm.png`,
    alt: 'Support arm von Mises stress contour plot',
    caption: 'Support-arm von Mises contour plot showing stress near the arm and pin interfaces.',
  },
  {
    src: `${projectPath}/fea-platform.png`,
    alt: 'Platform von Mises stress contour plot',
    caption: 'Platform von Mises contour plot highlighting stress around the pump support plate.',
  },
  {
    src: `${projectPath}/fea-pin.png`,
    alt: 'Pin von Mises stress contour plot',
    caption: 'Pin stress contour plot used with hand shear checks.',
  },
  {
    src: `${projectPath}/convergence-plot.png`,
    alt: 'Mesh convergence plot for support arm stress',
    caption: 'Mesh convergence plot showing support-arm stress stabilizing with refinement.',
  },
  {
    src: `${projectPath}/convergence-table.png`,
    alt: 'Mesh convergence table for SolidWorks finite element analysis',
    caption: 'Convergence table tracking stresses and deflection across mesh refinements.',
  },
  {
    src: `${projectPath}/beam-drawing.png`,
    alt: 'Beam drawing for the pump support platform',
    caption: 'Component drawing for the aluminum frame member.',
  },
  {
    src: `${projectPath}/pump-bridge-drawing.png`,
    alt: 'Pump bridge drawing for the pump support platform',
    caption: 'Pump bridge component drawing used for the modular frame assembly.',
  },
  {
    src: `${projectPath}/pump-support-drawing.png`,
    alt: 'Pump support drawing for the pump support platform',
    caption: 'Pump support component drawing showing the machined connection geometry.',
  },
  {
    src: `${projectPath}/support-arm-drawing.png`,
    alt: 'Support arm drawing for the pump support platform',
    caption: 'Support-arm drawing for the angled compression members.',
  },
  {
    src: `${projectPath}/test-results-table.png`,
    alt: 'Physical prototype validation table',
    caption: 'Prototype test data including weight, height, load, and measured deflection.',
  },
  {
    src: `${projectPath}/physical-prototype.png`,
    alt: 'Physical pump support platform prototype mounted in the frame',
    caption: 'Physical prototype installed in the frame during validation.',
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Pump Support Platform Design case study covering mechanical design, hand calculations, finite element analysis, prototyping, and validation of a centrifugal pump support system."
    />
    <title>Pump Support Platform Design | Rohan Joshi</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={asset('favicon-previous.png')} />
    <link rel="apple-touch-icon" href={asset('favicon-previous.png')} />
  </head>

  <body class="case-body">
    <header class="case-nav">
      <a class="case-brand" href={route()}>RJ</a>
      <nav aria-label="Pump support platform page navigation">
        <a href={route('#portfolio')}>Portfolio</a>
        <a href="#overview">Overview</a>
        <a href="#analysis">Analysis</a>
        <a href="#fea">FEA</a>
        <a href="#gallery">Gallery</a>
        <a href={route('resume/')}>Resume</a>
      </nav>
    </header>

    <main class="overflow-hidden bg-[#05070a] text-slate-100">
      <section
        class="relative grid min-h-screen items-end bg-cover bg-center px-6 pb-14 pt-28 sm:px-10 lg:px-16 lg:pb-20"
        style={`background-image: linear-gradient(90deg, rgba(5, 7, 10, 0.98) 0%, rgba(5, 7, 10, 0.78) 45%, rgba(5, 7, 10, 0.36) 100%), linear-gradient(180deg, rgba(5, 7, 10, 0.28) 0%, rgba(5, 7, 10, 0.94) 100%), url('${heroImage}');`}
      >
        <div class="mx-auto grid w-full max-w-7xl gap-10 lg:grid-cols-[minmax(0,1fr)_390px] lg:items-end">
          <div class="max-w-5xl">
            <a class="mb-10 inline-flex text-sm font-bold uppercase text-cyan-300 transition hover:text-white" href={route('#portfolio')}>
              Back to portfolio
            </a>
            <p class="mb-5 text-sm font-bold uppercase text-cyan-300">
              Structural design case study
            </p>
            <h1 class="max-w-5xl text-6xl font-black leading-[0.9] text-white sm:text-7xl lg:text-8xl">
              Pump Support Platform Design
            </h1>
            <p class="mt-8 max-w-3xl text-xl leading-8 text-slate-200 sm:text-2xl sm:leading-9">
              Design, analysis, and prototyping of a structural support system for a centrifugal pump
            </p>
          </div>

          <div class="grid gap-3 border border-white/15 bg-black/40 p-4 shadow-2xl backdrop-blur">
            <div class="grid grid-cols-2 gap-3">
              <div class="metric-card">
                <span>Flow Target</span>
                <strong>150 GPM</strong>
              </div>
              <div class="metric-card">
                <span>Head</span>
                <strong>60 ft</strong>
              </div>
              <div class="metric-card">
                <span>Test Load</span>
                <strong>115 lbf</strong>
              </div>
              <div class="metric-card">
                <span>Height</span>
                <strong>14 in</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="overview" class="section-shell border-t border-white/10">
        <div class="section-kicker">Overview</div>
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <h2 class="section-title">
            A modular aluminum frame designed to carry pump, pulley, and support reactions efficiently.
          </h2>
          <div class="copy-stack">
            <p>
              This project involved designing, analyzing, and prototyping a structural support platform for a centrifugal pump system. The design needed to support combined loading from pump weight, belt-driven pulley forces, and structural reactions, while remaining lightweight, modular, and manufacturable.
            </p>
            <p>
              The final system was validated through hand calculations, finite element analysis, and physical testing. The finished prototype used an aluminum frame, angled support arms, clevis-pin interfaces, and standard stock geometry to move load from the pump into the surrounding structure.
            </p>
            <p>
              The engineering focus was to replace excess material with better geometry, simplify fabrication, and confirm that analytical and simulation predictions matched physical performance.
            </p>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Design Requirements</div>
        <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <h2 class="section-title max-w-3xl">The platform had to support a realistic pump load case while staying compact and buildable.</h2>
          <p class="max-w-xl text-base leading-7 text-slate-400">
            Requirements combined hydraulic performance, structural margins, frame packaging, modular assembly, corrosion resistance, and a strict cost cap.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            requirements.map((item) => (
              <article class="group border border-white/10 bg-white/[0.035] p-6 transition duration-200 hover:-translate-y-1 hover:border-cyan-300/55 hover:bg-white/[0.06]">
                <p class="text-xs font-bold uppercase text-cyan-300">{item.label}</p>
                <h3 class="mt-4 text-3xl font-black text-white">{item.value}</h3>
                <p class="mt-4 text-sm leading-6 text-slate-400">{item.detail}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Engineering Approach</div>
        <div class="mb-10 grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
          <h2 class="section-title">The load path was solved analytically before the structure was refined in FEA.</h2>
          <p class="max-w-2xl text-lg leading-8 text-slate-400">
            Static equilibrium was used to compute support reactions from the pump weight, belt tensions, pulley torque, and frame constraints. Python was used to solve the reaction system and generate shear and moment diagrams, giving a traceable baseline before simulation.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {
            approach.map((principle) => (
              <article class="principle-card">
                <h3>{principle.title}</h3>
                <p>{principle.detail}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Initial Design</div>
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
          <div class="copy-stack">
            <h2 class="section-title">The first concept used too much material and created concentrated connection stresses.</h2>
            <p>
              The initial design relied on bulky solid components to resist the pump and pulley load case. That geometry was easy to reason about, but it used material inefficiently and carried load through heavy sections rather than targeted structural shapes.
            </p>
            <p>
              Free-body diagrams were developed to solve reactions at the wall and angled supports. The initial stress model identified critical locations near the platform center, through-holes, and pin connections, where bending, torsion, axial stress, and stress concentration effects combined.
            </p>
            <div class="grid gap-3 sm:grid-cols-3">
              <div class="stat-box">
                <span>Moment at G</span>
                <strong>743.9 lbf-in</strong>
              </div>
              <div class="stat-box">
                <span>Torque at G</span>
                <strong>122.6 lbf-in</strong>
              </div>
              <div class="stat-box">
                <span>Support S1</span>
                <strong>279.3 lbf</strong>
              </div>
            </div>
          </div>

          <div class="grid gap-5">
            <a class="image-panel" href={asset(`${projectPath}/free-body-diagrams.png`)} target="_blank" rel="noreferrer">
              <img src={asset(`${projectPath}/free-body-diagrams.png`)} alt="Free body diagrams for the pump support platform" loading="lazy" />
            </a>
            <div class="grid gap-5 sm:grid-cols-2">
              <a class="image-panel" href={asset(`${projectPath}/python-vm-diagrams.png`)} target="_blank" rel="noreferrer">
                <img src={asset(`${projectPath}/python-vm-diagrams.png`)} alt="Python generated shear and moment diagrams" loading="lazy" />
              </a>
              <a class="image-panel" href={asset(`${projectPath}/critical-stress-locations.png`)} target="_blank" rel="noreferrer">
                <img src={asset(`${projectPath}/critical-stress-locations.png`)} alt="Critical stress location diagram" loading="lazy" />
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Design Iteration</div>
        <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div class="grid gap-5">
            <a class="image-panel" href={asset(`${projectPath}/material-support-arm.png`)} target="_blank" rel="noreferrer">
              <img src={asset(`${projectPath}/material-support-arm.png`)} alt="Support arm material selection from the report" loading="lazy" />
            </a>
            <div class="grid gap-5 sm:grid-cols-2">
              <a class="image-panel" href={asset(`${projectPath}/material-pump-platform.png`)} target="_blank" rel="noreferrer">
                <img src={asset(`${projectPath}/material-pump-platform.png`)} alt="Pump platform material selection from the report" loading="lazy" />
              </a>
              <a class="image-panel" href={asset(`${projectPath}/material-pin.png`)} target="_blank" rel="noreferrer">
                <img src={asset(`${projectPath}/material-pin.png`)} alt="Pin material selection from the report" loading="lazy" />
              </a>
            </div>
          </div>

          <div class="copy-stack">
            <h2 class="section-title">Simulation and fabrication constraints pushed the design toward a lighter frame architecture.</h2>
            <p>
              The design shifted from solid, bulky components to a frame-based system using aluminum I-beams, rectangular tubing, and angled members. This reduced unnecessary material while keeping stiffness in the directions that mattered most.
            </p>
            <p>
              Iteration was driven by both finite element results and practical manufacturing limits. Rather than relying on complex milling, the final architecture used standard stock and simple drilling and reaming operations for the clevis-pin and bolted connections.
            </p>
            <div class="grid gap-3 sm:grid-cols-2">
              <div class="stat-box">
                <span>Primary stock</span>
                <strong>I-beams and tubing</strong>
              </div>
              <div class="stat-box">
                <span>Fabrication</span>
                <strong>Drill and ream</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Final Design</div>
        <div class="grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
          <div class="copy-stack">
            <h2 class="section-title">The final assembly routes load from the pump into the frame through modular aluminum members.</h2>
            <p>
              The final design used an aluminum frame structure with I-beams, rectangular tubing, angled supports, and clevis-pin connections. The pump load is carried into the platform, transferred into the support arms, and then reacted by the frame and wall-mounted interfaces.
            </p>
            <p>
              The clevis pins made the system modular and removable, while the frame geometry allowed high stiffness without requiring a heavy solid platform. The final physical prototype measured 14 in tall, staying well below the 24 in maximum height requirement.
            </p>
            <div class="grid gap-3 sm:grid-cols-2">
              <div class="stat-box">
                <span>Prototype height</span>
                <strong>14 in</strong>
              </div>
              <div class="stat-box">
                <span>Load path</span>
                <strong>Platform to arms to frame</strong>
              </div>
            </div>
          </div>

          <div class="grid gap-5">
            <a class="image-panel" href={asset(`${projectPath}/cad-isometric.png`)} target="_blank" rel="noreferrer">
              <img src={asset(`${projectPath}/cad-isometric.png`)} alt="CAD isometric view of the pump support platform" loading="lazy" />
            </a>
            <a class="image-panel" href={asset(`${projectPath}/assembly-drawing.png`)} target="_blank" rel="noreferrer">
              <img src={asset(`${projectPath}/assembly-drawing.png`)} alt="Assembly drawing of the pump support platform" loading="lazy" />
            </a>
          </div>
        </div>
      </section>

      <section id="analysis" class="section-shell border-t border-white/10">
        <div class="section-kicker">Engineering Analysis</div>
        <div class="mb-10 grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
          <h2 class="section-title">Hand calculations sized the platform, support arms, pins, and deflection response.</h2>
          <p class="max-w-2xl text-lg leading-8 text-slate-400">
            The analytical model combined machine design methods with mechanics of materials. Yielding was checked with von Mises stress, buckling was checked with Euler stability, and deflection was estimated by superposition before comparison against FEA.
          </p>
        </div>

        <div class="grid gap-5 lg:grid-cols-4">
          <article class="analysis-card">
            <p class="analysis-letter">A</p>
            <h3>Stress Analysis</h3>
            <p>
              The pump platform was checked under bending, torsion, axial loading, and transverse shear. Stress concentration factors were applied at holes and interfaces where load entered the structure.
            </p>
            <div class="calc-box">
              <span>Critical locations</span>
              <strong>Platform center and support-arm pin holes</strong>
            </div>
            <p>
              Those locations were carried forward into both hand calculations and simulation review.
            </p>
          </article>

          <article class="analysis-card">
            <p class="analysis-letter">B</p>
            <h3>Failure Analysis</h3>
            <p>
              Von Mises stress was used to evaluate yielding in ductile aluminum under combined loading. The platform and support arms remained comfortably above the minimum design margin.
            </p>
            <div class="calc-box">
              <span>Safety factors</span>
              <strong>Platform about 9, support arm about 5.6</strong>
            </div>
            <p>
              The report also checked pin shear separately because the pins used different material behavior.
            </p>
          </article>

          <article class="analysis-card">
            <p class="analysis-letter">C</p>
            <h3>Buckling Analysis</h3>
            <p>
              The angled support arms were treated as compression members and evaluated with Euler buckling. Stability margin was much higher than the yield margin.
            </p>
            <div class="calc-box">
              <span>Buckling FOS</span>
              <strong>About 46.6 for the support arms</strong>
            </div>
            <p>
              This confirmed that the final arm geometry was not close to a column instability limit.
            </p>
          </article>

          <article class="analysis-card">
            <p class="analysis-letter">D</p>
            <h3>Deflection</h3>
            <p>
              Deflection was estimated analytically using superposition and then compared against SolidWorks. The initial sizing target was below 1 mm, while the prototype test reported about 2.5 mm under full applied load.
            </p>
            <div class="calc-box">
              <span>Model comparison</span>
              <strong>2.441 mm hand calc, 2.807 mm FEA</strong>
            </div>
            <p>
              The final measured result remained within the validation allowance documented during physical testing.
            </p>
          </article>
        </div>
      </section>

      <section id="fea" class="section-shell border-t border-white/10">
        <div class="section-kicker">Finite Element Analysis</div>
        <div class="mb-10 grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
          <h2 class="section-title">SolidWorks FEA refined the critical stress predictions and checked mesh sensitivity.</h2>
          <p class="max-w-2xl text-lg leading-8 text-slate-400">
            The simulation used simplified loading assumptions, a rigid-body approximation for the pump, and revolute-joint behavior at pin connections. Loads included pump weight, belt force, torque, and gravity.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <a class="image-panel" href={asset(`${projectPath}/applied-loads.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/applied-loads.png`)} alt="Applied loads in the SolidWorks FEA model" loading="lazy" />
          </a>
          <a class="image-panel" href={asset(`${projectPath}/fea-full-structure.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/fea-full-structure.png`)} alt="Full structure von Mises stress contour" loading="lazy" />
          </a>
        </div>

        <div class="mt-5 grid gap-5 md:grid-cols-3">
          <a class="image-panel" href={asset(`${projectPath}/fea-support-arm.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/fea-support-arm.png`)} alt="Support arm von Mises contour" loading="lazy" />
          </a>
          <a class="image-panel" href={asset(`${projectPath}/fea-platform.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/fea-platform.png`)} alt="Platform von Mises contour" loading="lazy" />
          </a>
          <a class="image-panel" href={asset(`${projectPath}/fea-pin.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/fea-pin.png`)} alt="Pin von Mises contour" loading="lazy" />
          </a>
        </div>

        <div class="mt-10 grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div class="copy-stack">
            <h2 class="section-title">Mesh refinement continued until the results stabilized.</h2>
            <p>
              A convergence study refined the mesh until the final stress changes were below about 5 percent. This gave confidence that peak stress trends were driven by the geometry and load path rather than mesh artifacts.
            </p>
            <p>
              The converged simulation predicted stresses in the support arm, platform, and pin, then compared deflection against analytical calculations and the physical test.
            </p>
          </div>

          <div class="data-table" aria-label="Finite element analysis results">
            {
              feaRows.map(([part, value, note]) => (
                <div>
                  <strong>{part}</strong>
                  <span>{value}</span>
                  <p>{note}</p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          <a class="image-panel" href={asset(`${projectPath}/convergence-plot.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/convergence-plot.png`)} alt="Mesh convergence plot for the support arm" loading="lazy" />
          </a>
          <a class="image-panel" href={asset(`${projectPath}/convergence-table.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/convergence-table.png`)} alt="Mesh convergence table for FEA results" loading="lazy" />
          </a>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Results and Validation</div>
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <a class="image-panel" href={asset(`${projectPath}/physical-prototype.png`)} target="_blank" rel="noreferrer">
            <img src={asset(`${projectPath}/physical-prototype.png`)} alt="Physical pump support platform prototype mounted in the frame" loading="lazy" />
          </a>

          <div class="copy-stack">
            <h2 class="section-title">The prototype supported the full validation load with measured deflection close to the model.</h2>
            <p>
              The final prototype successfully supported the applied load without visible structural failure. The measured deflection was about 2.5 mm under 115 lbf, and the report documented this as within the validation limit used during physical testing.
            </p>
            <p>
              SolidWorks predicted 2.807 mm of deflection, while the hand calculation predicted 2.441 mm. The simulation and experiment aligned within about 20 percent, supporting the combined analytical and FEA modeling approach.
            </p>
            <div class="data-table" aria-label="Physical prototype validation results">
              {
                validationRows.map(([label, value, note]) => (
                  <div>
                    <strong>{label}</strong>
                    <span>{value}</span>
                    <p>{note}</p>
                  </div>
                ))
              }
            </div>
            <a class="image-panel" href={asset(`${projectPath}/test-results-table.png`)} target="_blank" rel="noreferrer">
              <img src={asset(`${projectPath}/test-results-table.png`)} alt="Prototype validation data table" loading="lazy" />
            </a>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <div class="section-kicker">Manufacturing</div>
            <h2 class="section-title">The final geometry minimized custom machining and favored standard aluminum stock.</h2>
          </div>
          <div class="copy-stack">
            <p>
              The fabrication workflow relied on standard aluminum I-beams, rectangular tubes, angle sections, and simple drilled or reamed holes. This reduced shop time and avoided the complex machining that the heavier early concept would have required.
            </p>
            <p>
              Clevis-pin connections made the support arms removable and simplified assembly. Bolted and pinned interfaces also made it easier to inspect, fit, and adjust the prototype during frame installation.
            </p>
            <p>
              During fit-up, minor interference between the support arms and frame was resolved by carefully filing the top corner of the affected arms. The adjustment removed minimal material and did not change the validated structural load path.
            </p>
            <div class="grid gap-5 sm:grid-cols-2">
              <a class="image-panel" href={asset(`${projectPath}/pump-bridge-drawing.png`)} target="_blank" rel="noreferrer">
                <img src={asset(`${projectPath}/pump-bridge-drawing.png`)} alt="Pump bridge drawing" loading="lazy" />
