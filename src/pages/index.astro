---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rohan Joshi</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" />
  </head>

  <body class="bg-black text-white font-[Inter] antialiased">
    <main class="max-w-6xl mx-auto px-6 md:px-10 py-24">

      <!-- HERO -->
      <section class="min-h-screen flex flex-col justify-center relative overflow-hidden">

        <!-- Background Image -->
        <img
          src="/headshot.jpg"
          alt="Rohan Joshi"
          class="absolute inset-0 w-full h-full object-cover opacity-20 blur-sm"
        />

        <!-- Overlay -->
        <div class="absolute inset-0 bg-black/70"></div>

        <!-- Content -->
        <div class="relative z-10">
          <p class="text-gray-500 mb-4 tracking-[0.2em] uppercase text-sm">
            Mechanical Engineering • Aerospace • Robotics
          </p>

          <h1 class="text-7xl md:text-8xl font-extrabold leading-none mb-8">
            Rohan Joshi
          </h1>

          <p class="text-lg md:text-2xl text-gray-400 max-w-3xl leading-relaxed">
            Mechanical Engineering student at Duke University focused on aerospace,
            rocketry, robotics, and interdisciplinary engineering systems.
          </p>
        </div>

      </section>

      <!-- ABOUT -->
      <section class="py-32 border-t border-gray-800">
        <h2 class="text-4xl font-bold mb-10">About</h2>

        <div class="max-w-4xl space-y-6 text-lg text-gray-400 leading-relaxed">
          <p>
            I am a Mechanical Engineering student at Duke University pursuing
            certificates in Aerospace Engineering and Innovation & Entrepreneurship.
          </p>

          <p>
            My work spans aerospace systems, structural analysis, aerodynamics,
            additive manufacturing, embedded systems, and nanotechnology research.
          </p>

          <p>
            I enjoy designing and building systems that bridge the gap between
            physical engineering and computational tools.
          </p>
        </div>
      </section>

      <!-- EXPERIENCE -->
      <section class="py-32 border-t border-gray-800">
        <h2 class="text-4xl font-bold mb-16">Experience</h2>

        <div class="space-y-16">

          <div>
            <h3 class="text-2xl font-semibold">
              SpaceX — Dragon Structures Engineering Intern
            </h3>
            <p class="text-gray-500 text-sm mb-2">Summer 2025</p>
            <p class="text-gray-400 max-w-4xl">
              Worked on structural analysis and qualification testing for Dragon
              flight hardware and ground support equipment.
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-semibold">
              General Dynamics — Integration & Test Intern
            </h3>
            <p class="text-gray-500 text-sm mb-2">Summer 2024</p>
            <p class="text-gray-400 max-w-4xl">
              Designed testing fixtures, performed FEA analysis, and developed
              Python-based systems for testing workflows.
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-semibold">
              Embry-Riddle — Research Intern
            </h3>
            <p class="text-gray-500 text-sm mb-2">Summer 2023</p>
            <p class="text-gray-400 max-w-4xl">
              Conducted nanotechnology research on Organic Electrochemical
              Transistors (OECTs) for aerospace biosensing applications.
            </p>
          </div>

        </div>
      </section>

      <!-- PROJECTS -->
      <section class="py-32 border-t border-gray-800">
        <h2 class="text-4xl font-bold mb-16">Projects</h2>

        <div class="grid md:grid-cols-2 gap-8">

          <div class="border border-gray-800 rounded-3xl p-8 hover:border-white transition duration-300">
            <h3 class="text-2xl font-semibold mb-4">FINsight</h3>
            <p class="text-gray-400">
              Developed a strain-sensing fin system for rocket flight analysis using embedded systems and PCB design.
            </p>
          </div>

          <div class="border border-gray-800 rounded-3xl p-8 hover:border-white transition duration-300">
            <h3 class="text-2xl font-semibold mb-4">OECT Biosensor</h3>
            <p class="text-gray-400">
              Conducted nanotechnology research on glucose sensors for aerospace environments.
            </p>
          </div>

          <div class="border border-gray-800 rounded-3xl p-8 hover:border-white transition duration-300">
            <h3 class="text-2xl font-semibold mb-4">Trash Trap System</h3>
            <p class="text-gray-400">
              Designed an environmentally safe filtration system for Beaver Marsh to prevent debris buildup.
            </p>
          </div>

          <div class="border border-gray-800 rounded-3xl p-8 hover:border-white transition duration-300">
            <h3 class="text-2xl font-semibold mb-4">Rocketry Systems</h3>
            <p class="text-gray-400">
              Worked on avionics, air brakes, and simulation systems for aerospace projects.
            </p>
          </div>

        </div>
      </section>

      <!-- CONTACT -->
      <section class="py-32 border-t border-gray-800">
        <h2 class="text-4xl font-bold mb-10">Contact</h2>

        <div class="flex gap-6">
          <a href="mailto:rohan.joshi@duke.edu" class="underline">Email</a>
          <a href="https://github.com/rjoshi4464-rgb" class="underline">GitHub</a>
          <a href="https://www.linkedin.com/in/rohanjoshi2/" class="underline">LinkedIn</a>
        </div>
      </section>

      <!-- FOOTER -->
      <footer class="py-20 border-t border-gray-800 text-gray-600 text-sm">
        © 2026 Rohan Joshi
      </footer>

    </main>
  </body>
</html>
