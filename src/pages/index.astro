---
import '../styles/global.css';

const experiences = [
  {
    company: 'SpaceX',
    role: 'Dragon Structures Engineering Intern',
    date: 'Summer 2025',
    summary:
      'Worked on structural analysis and qualification testing for Dragon flight hardware and ground support equipment.',
  },
  {
    company: 'General Dynamics',
    role: 'Integration & Test Intern',
    date: 'Summer 2024',
    summary:
      'Designed testing fixtures, performed FEA analysis, and developed Python-based systems for testing workflows.',
  },
  {
    company: 'Embry-Riddle',
    role: 'Research Intern',
    date: 'Summer 2023',
    summary:
      'Conducted nanotechnology research on Organic Electrochemical Transistors for aerospace biosensing applications.',
  },
];

const projects = [
  {
    name: 'FINsight',
    tag: 'Rocketry',
    summary:
      'A strain-sensing fin system for rocket flight analysis using embedded systems, PCB design, and structural validation.',
  },
  {
    name: 'OECT Biosensor',
    tag: 'Research',
    summary:
      'Nanotechnology research focused on glucose sensors designed for demanding aerospace environments.',
  },
  {
    name: 'Trash Trap System',
    tag: 'Design',
    summary:
      'An environmentally safe filtration system built to reduce debris accumulation in Beaver Marsh.',
  },
  {
    name: 'Rocketry Systems',
    tag: 'Aerospace',
    summary:
      'Avionics, air-brake, and simulation work across student aerospace systems and launch operations.',
  },
];

const focusAreas = [
  'Structural analysis',
  'Aerospace systems',
  'Robotics',
  'Embedded hardware',
  'Additive manufacturing',
  'Research translation',
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Rohan Joshi is a Mechanical Engineering student at Duke University focused on aerospace, robotics, rocketry, and interdisciplinary engineering systems."
    />
    <title>Rohan Joshi | Mechanical Engineering</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" />
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a href="#top" class="brand" aria-label="Rohan Joshi home">
          <span class="brand-mark">RJ</span>
          <span>Rohan Joshi</span>
        </a>

        <nav aria-label="Primary navigation">
          <a href="#about">About</a>
          <a href="#experience">Experience</a>
          <a href="#projects">Projects</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <main id="top">
        <section class="hero" aria-labelledby="hero-title">
          <div class="hero-copy">
            <p class="eyebrow">Mechanical Engineering / Aerospace / Robotics</p>
            <h1 id="hero-title">Rohan Joshi</h1>
            <p class="hero-lede">
              Mechanical Engineering student at Duke University building across
              aerospace structures, rocketry, robotics, and interdisciplinary
              engineering systems.
            </p>

            <div class="hero-actions" aria-label="Contact links">
              <a class="button primary" href="mailto:rohan.joshi@duke.edu">
                Email
              </a>
              <a class="button secondary" href="#projects">View Work</a>
            </div>
          </div>

          <aside class="hero-panel" aria-label="Profile summary">
            <img src="/headshot.jpg" alt="Portrait of Rohan Joshi" />
            <div class="panel-content">
              <p>Duke University</p>
              <strong>Mechanical Engineering</strong>
              <span>Aerospace Engineering / Innovation & Entrepreneurship</span>
            </div>
          </aside>
        </section>

        <section class="signal-row" aria-label="Engineering focus areas">
          <div>
            <span>Focus</span>
            <strong>Physical systems with computational rigor</strong>
          </div>
          <div>
            <span>Practice</span>
            <strong>Analysis, prototyping, test, iteration</strong>
          </div>
          <div>
            <span>Now</span>
            <strong>Aerospace structures and robotics</strong>
          </div>
        </section>

        <section id="about" class="section about-grid">
          <div>
            <p class="section-kicker">About</p>
            <h2>Engineering from concept to tested hardware.</h2>
          </div>

          <div class="section-copy">
            <p>
              I am a Mechanical Engineering student at Duke University pursuing
              certificates in Aerospace Engineering and Innovation &
              Entrepreneurship.
            </p>
            <p>
              My work spans aerospace systems, structural analysis,
              aerodynamics, additive manufacturing, embedded systems, and
              nanotechnology research.
            </p>
            <p>
              I enjoy designing and building systems that bridge physical
              engineering and computational tools.
            </p>
          </div>
        </section>

        <section class="focus-strip" aria-label="Technical strengths">
          {focusAreas.map((area) => <span>{area}</span>)}
        </section>

        <section id="experience" class="section">
          <div class="section-heading">
            <p class="section-kicker">Experience</p>
            <h2>Recent engineering roles.</h2>
          </div>

          <div class="timeline">
            {
              experiences.map((item) => (
                <article class="timeline-item">
                  <div>
                    <span>{item.date}</span>
                    <h3>{item.company}</h3>
                  </div>
                  <div>
                    <p class="role">{item.role}</p>
                    <p>{item.summary}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section id="projects" class="section">
          <div class="section-heading">
            <p class="section-kicker">Projects</p>
            <h2>Selected work.</h2>
          </div>

          <div class="project-grid">
            {
              projects.map((project) => (
                <article class="project-card">
                  <div class="project-meta">
                    <span>{project.tag}</span>
                  </div>
                  <h3>{project.name}</h3>
                  <p>{project.summary}</p>
                </article>
              ))
            }
          </div>
        </section>

        <section id="contact" class="section contact-section">
          <div>
            <p class="section-kicker">Contact</p>
            <h2>Let's build something precise.</h2>
          </div>

          <div class="contact-actions">
            <a class="button primary" href="mailto:rohan.joshi@duke.edu">
              Email
            </a>
            <a class="button secondary" href="https://github.com/rjoshi4464-rgb">
              GitHub
            </a>
            <a
              class="button secondary"
              href="https://www.linkedin.com/in/rohanjoshi2/"
            >
              LinkedIn
            </a>
          </div>
        </section>
      </main>

      <footer>
        <span>© 2026 Rohan Joshi</span>
        <span>Mechanical Engineering / Aerospace / Robotics</span>
      </footer>
    </div>
  </body>
</html>
