---
import '../styles/global.css';
import { projects } from '../data/projects';

const base = `${import.meta.env.BASE_URL}/`.replace(/\/+$/, '/');
const asset = (path: string) => `${base}${path}`;
const route = (path = '') => `${base}${path}`;
const portfolioOrder = [
  'active-suspension-capstone',
  'spacex-dragon-structures',
  'finsight',
  'rocketry-systems',
  'oect-biosensor',
  'trash-trap',
];
const orderedProjects = portfolioOrder
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter((project): project is (typeof projects)[number] => Boolean(project));
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Rohan Joshi is a Mechanical Engineering student at Duke University focused on aerospace, robotics, rocketry, and interdisciplinary engineering systems."
    />
    <title>Rohan Joshi | Engineering Portfolio</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cabin:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={asset('favicon-previous.png')} />
    <link rel="apple-touch-icon" href={asset('favicon-previous.png')} />
  </head>

  <body>
    <header class="site-nav">
      <a class="nav-brand" href="#home">RJ</a>
      <nav aria-label="Primary navigation">
        <a href="#portfolio">Portfolio</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="home">
      <section class="splash">
        <div class="intro-card">
          <p class="intro-name">Rohan Joshi</p>
          <p class="pronunciation">[/roh-hun/ /joe-shee/] &nbsp; noun</p>
          <div class="intro-rule"></div>
          <p class="intro-definition">
            mechanical engineer, aerospace builder, roboticist, researcher.
          </p>
        </div>

        <img
          class="intro-photo"
          src={asset('headshot.jpg')}
          alt="Portrait of Rohan Joshi"
        />

        <a class="pointer pointer-portfolio" href="#portfolio">
          Portfolio
          <span>v</span>
        </a>
        <a class="pointer pointer-about" href="#about">
          About
          <span>v</span>
        </a>
        <a class="pointer pointer-contact" href="#contact">
          Contact
          <span>v</span>
        </a>
      </section>

      <section class="about-panel" id="about">
        <div>
          <p class="section-label">About</p>
          <h1>Mechanical engineering, from concept to tested hardware.</h1>
        </div>
        <div class="about-copy">
          <p>
            I am a Mechanical Engineering student at Duke University pursuing
            certificates in Aerospace Engineering and Innovation &
            Entrepreneurship.
          </p>
          <p>
            My work spans aerospace systems, structural analysis, aerodynamics,
            additive manufacturing, and nanotechnology research.
          </p>
          <p>
            I enjoy designing and building systems that bridge physical
            engineering and analysis softwares.
          </p>
        </div>
      </section>

      <section class="portfolio" id="portfolio" aria-label="Project portfolio">
        {
          orderedProjects.map((project) => (
            <a
              class="portfolio-entry"
              href={route(`projects/${project.slug}/`)}
              aria-label={`Open ${project.shortTitle} project page`}
            >
              <img src={asset(project.image)} alt={project.imageAlt} loading="lazy" />
              <div class="portfolio-overlay">
                <div>
                  <span>{project.shortTitle}</span>
                  <em>{project.summary}</em>
                </div>
              </div>
            </a>
          ))
        }
      </section>

      <footer class="site-footer" id="contact">
        <span>&copy; 2026 Rohan Joshi</span>
        <div>
          <a href="mailto:rohan.joshi@duke.edu">Email</a>
          <a href="https://github.com/rjoshi4464-rgb">GitHub</a>
          <a href="https://www.linkedin.com/in/rohanjoshi2/">LinkedIn</a>
        </div>
      </footer>
    </main>
  </body>
</html>
