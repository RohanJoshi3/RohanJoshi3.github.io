---
import '../styles/global.css';
import AOS from 'aos';
import 'aos/dist/aos.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rohan Joshi</title>

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

    <!-- Favicon -->
    <link rel="icon" href="/rohanjoshi.github.io/favicon.ico" />
  </head>

  <body class="bg-black text-white font-[Inter]">
    <main class="max-w-6xl mx-auto px-6 md:px-10 py-24">

      <!-- HERO -->
      <section data-aos="fade-up" class="min-h-screen flex flex-col justify-center">
        <p class="text-gray-500 mb-4 tracking-[0.2em] uppercase text-sm">
          Software Developer
        </p>

        <h1 class="text-7xl md:text-8xl font-extrabold leading-tight mb-6">
          Rohan Joshi
        </h1>

        <p class="text-lg md:text-xl text-gray-400 max-w-2xl leading-relaxed">
          Building software, systems, and experimental projects.
          Interested in AI, operating systems, and full-stack development.
        </p>

        <div class="flex gap-4 mt-10">
          <a
            href="https://github.com/rjoshi4464-rgb"
            class="border border-white px-6 py-3 rounded-full hover:bg-white hover:text-black transition duration-300"
          >
            GitHub
          </a>

          <a
            href="#projects"
            class="border border-gray-700 px-6 py-3 rounded-full hover:border-white transition duration-300"
          >
            Projects
          </a>
        </div>
      </section>

      <!-- ABOUT -->
      <section data-aos="fade-up" class="py-32 border-t border-gray-800">
        <h2 class="text-4xl font-bold mb-10">
          About
        </h2>

        <p class="text-gray-400 text-lg leading-relaxed max-w-3xl">
          I'm a developer focused on building performant software and thoughtful user experiences.
          I enjoy working across systems, machine learning, and modern web technologies.
        </p>
      </section>

      <!-- PROJECTS -->
      <section id="projects" data-aos="fade-up" class="py-32 border-t border-gray-800">
        <h2 class="text-4xl font-bold mb-12">
          Projects
        </h2>

        <div class="grid md:grid-cols-2 gap-8">

          <a href="#" class="group border border-gray-800 rounded-2xl p-8 hover:border-white transition duration-300">
            <h3 class="text-2xl font-semibold mb-4 group-hover:underline">
              Orbital Osiris →
            </h3>

            <p class="text-gray-400 leading-relaxed">
              Experimental software project exploring systems, interfaces, and automation.
            </p>
          </a>

          <a href="#" class="group border border-gray-800 rounded-2xl p-8 hover:border-white transition duration-300">
            <h3 class="text-2xl font-semibold mb-4 group-hover:underline">
              Project Two →
            </h3>

            <p class="text-gray-400 leading-relaxed">
              Add another project description here.
            </p>
          </a>

        </div>
      </section>

      <!-- FOOTER -->
      <footer class="py-20 border-t border-gray-800 text-gray-500">
        © 2026 Rohan Joshi
      </footer>

    </main>

    <!-- AOS Init -->
    <script>
      AOS.init({
        duration: 800,
        once: true,
      });
    </script>
  </body>
</html>
