---
import '../styles/global.css';

const base = `${import.meta.env.BASE_URL}/`.replace(/\/+$/, '/');
const asset = (path: string) => `${base}${path}`;
const route = (path = '') => `${base}${path}`;

const heroImage = asset('projects/pressure-vessel/final-machined-vessel.jpg');

const requirements = [
  {
    label: 'Operating Pressure',
    value: '750 psig',
    detail: 'Hydrostatic pressure target for the assembled vessel.',
  },
  {
    label: 'Fluid Volume',
    value: '50-60 cc',
    detail: 'Final internal volume measured from CAD at 58.7 cc.',
  },
  {
    label: 'Seal System',
    value: '219 O-ring',
    detail: 'Static face seal sized with Parker handbook guidance.',
  },
  {
    label: 'Fluid Port',
    value: '0.25 in NPT',
    detail: 'Single centered threaded port for filling and testing.',
  },
  {
    label: 'Fabrication',
    value: 'Manual machines',
    detail: 'Lathe and mill workflow with simplified setups.',
  },
  {
    label: 'Budget',
    value: 'Under $100',
    detail: 'Material and purchased hardware constrained by project cost.',
  },
];

const finalSpecs = [
  ['Material', 'Aluminum 6061-T6'],
  ['Outer diameter', '2.500 in'],
  ['Inner diameter', '1.250 in'],
  ['Wall thickness', '0.625 in'],
  ['Internal cavity', '2.92 in long'],
  ['Internal volume', '3.58 in3 / 58.7 cc'],
  ['Fasteners', 'Four M6-1 bolts'],
  ['Seal geometry', '1.285 in ID, 1.659 in OD, 0.112 in depth'],
];

const gallery = [
  {
    src: 'projects/pressure-vessel/final-machined-vessel.jpg',
    alt: 'Final machined aluminum pressure vessel with brass fitting',
    caption: 'Final machined vessel used as the tested pressure assembly.',
  },
  {
    src: 'projects/pressure-vessel/final-design-cad-photo.jpg',
    alt: 'Final CAD rendering beside manufactured pressure vessel',
    caption: 'CAD model compared with the manufactured vessel.',
  },
  {
    src: 'projects/pressure-vessel/design-evolution.png',
    alt: 'Pressure vessel initial and final CAD design evolution',
    caption: 'Design evolution from flange-based geometry to compact cylinder.',
  },
  {
    src: 'projects/pressure-vessel/assembly-drawing.png',
    alt: 'Assembly drawing for the final pressure vessel',
    caption: 'Final assembly drawing with section view and fastener layout.',
  },
  {
    src: 'projects/pressure-vessel/original-flange-drawing.png',
    alt: 'Original flange pressure vessel drawing',
    caption: 'Original flange design used during the manufacturability trade.',
  },
  {
    src: 'projects/pressure-vessel/original-end-cap-drawing.png',
    alt: 'Original end cap drawing',
    caption: 'Original end cap drawing before as-built updates.',
  },
  {
    src: 'projects/pressure-vessel/as-built-vessel-drawing.png',
    alt: 'As-built pressure vessel drawing',
    caption: 'As-built vessel drawing reflecting final machined dimensions.',
  },
  {
    src: 'projects/pressure-vessel/as-built-end-cap-drawing.png',
    alt: 'As-built pressure vessel end cap drawing',
    caption: 'As-built end cap drawing for the four-bolt closure.',
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Pressure Vessel Design case study covering design, analysis, machining, and validation of a 750 psi aluminum pressure vessel."
    />
    <title>Pressure Vessel Design | Rohan Joshi</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={asset('favicon-previous.png')} />
    <link rel="apple-touch-icon" href={asset('favicon-previous.png')} />
  </head>

  <body class="pv-body">
    <header class="pv-nav">
      <a class="pv-brand" href={route()}>RJ</a>
      <nav aria-label="Pressure vessel page navigation">
        <a href={route('#portfolio')}>Portfolio</a>
        <a href="#overview">Overview</a>
        <a href="#analysis">Analysis</a>
        <a href="#gallery">Gallery</a>
        <a href={route('resume/')}>Resume</a>
      </nav>
    </header>

    <main class="overflow-hidden bg-[#05070a] text-slate-100">
      <section
        class="relative grid min-h-screen items-end bg-cover bg-center px-6 pb-14 pt-28 sm:px-10 lg:px-16 lg:pb-20"
        style={`background-image: linear-gradient(90deg, rgba(5, 7, 10, 0.96) 0%, rgba(5, 7, 10, 0.78) 44%, rgba(5, 7, 10, 0.42) 100%), linear-gradient(180deg, rgba(5, 7, 10, 0.42) 0%, rgba(5, 7, 10, 0.92) 100%), url('${heroImage}');`}
      >
        <div class="mx-auto grid w-full max-w-7xl gap-10 lg:grid-cols-[minmax(0,1fr)_380px] lg:items-end">
          <div class="max-w-5xl">
            <a class="mb-10 inline-flex text-sm font-bold uppercase tracking-[0.18em] text-cyan-300 transition hover:text-white" href={route('#portfolio')}>
              Back to portfolio
            </a>
            <p class="mb-5 text-sm font-bold uppercase tracking-[0.28em] text-cyan-300">
              Mechanical design case study
            </p>
            <h1 class="max-w-5xl text-6xl font-black leading-[0.88] tracking-tight text-white sm:text-7xl lg:text-8xl">
              Pressure Vessel Design
            </h1>
            <p class="mt-8 max-w-3xl text-xl leading-8 text-slate-200 sm:text-2xl sm:leading-9">
              Design, analysis, machining, and validation of a 750 psi aluminum pressure vessel
            </p>
          </div>

          <div class="grid gap-3 border border-white/15 bg-black/38 p-4 shadow-2xl backdrop-blur">
            <div class="grid grid-cols-2 gap-3">
              <div class="border border-white/10 bg-white/[0.06] p-4">
                <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Pressure</span>
                <strong class="mt-2 block text-3xl font-black text-white">750 psi</strong>
              </div>
              <div class="border border-white/10 bg-white/[0.06] p-4">
                <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Volume</span>
                <strong class="mt-2 block text-3xl font-black text-white">58.7 cc</strong>
              </div>
              <div class="border border-white/10 bg-white/[0.06] p-4">
                <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Material</span>
                <strong class="mt-2 block text-2xl font-black text-white">6061-T6</strong>
              </div>
              <div class="border border-white/10 bg-white/[0.06] p-4">
                <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">Test</span>
                <strong class="mt-2 block text-2xl font-black text-white">No leak</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="overview" class="section-shell border-t border-white/10">
        <div class="section-kicker">Overview</div>
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <h2 class="section-title">
            A compact aluminum vessel designed around pressure safety, sealing reliability, and manufacturability.
          </h2>
          <div class="copy-stack">
            <p>
              This project centered on designing, analyzing, machining, assembling, and testing a cylindrical aluminum pressure vessel capable of containing water at 750 psig while meeting a 50-60 cc internal volume requirement.
            </p>
            <p>
              The final design used a simplified 6061-T6 cylindrical body with a bored central cavity, a threaded 0.25 in NPT port, a four-bolt end cap, and a static O-ring seal. The geometry was intentionally conservative: wall thickness, fastener preload, and sealing dimensions were selected to make the part practical to machine and robust during repeated handling and testing.
            </p>
            <p>
              Hand calculations were used before machining to validate pressure stress, O-ring gland geometry, fastener separation, preload, and joint safety factors. The completed vessel successfully held the required 750 psi during physical testing without leakage.
            </p>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Design Requirements</div>
        <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <h2 class="section-title max-w-3xl">The design brief balanced pressure containment with shop-floor constraints.</h2>
          <p class="max-w-xl text-base leading-7 text-slate-400">
            Requirements came from the project specification and were carried through the CAD model, calculations, bill of materials, and test plan.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            requirements.map((item) => (
              <article class="group border border-white/10 bg-white/[0.035] p-6 transition duration-200 hover:-translate-y-1 hover:border-cyan-300/55 hover:bg-white/[0.06]">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-300">{item.label}</p>
                <h3 class="mt-4 text-3xl font-black text-white">{item.value}</h3>
                <p class="mt-4 text-sm leading-6 text-slate-400">{item.detail}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Design Evolution</div>
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <a class="image-panel" href={asset('projects/pressure-vessel/design-evolution.png')} target="_blank" rel="noreferrer">
            <img
              src={asset('projects/pressure-vessel/design-evolution.png')}
              alt="Pressure vessel initial and final design evolution"
              loading="lazy"
            />
          </a>
          <div class="copy-stack">
            <h2 class="section-title">Manufacturability drove the move away from a flange-heavy concept.</h2>
            <p>
              The initial concept used a flange-based closure with a bolt and nut stack-up. It achieved the basic sealing concept, but added unnecessary turning operations, more material removal, and more setup complexity on manual machines.
            </p>
            <p>
              The design was simplified into a uniform-diameter cylindrical body with threaded holes in the vessel itself. This eliminated extra lathe work, reduced the bolt count to four, kept the bolt pattern symmetric at 90 degree spacing, and made the O-ring gland accessible to machine between the bore and bolt circle.
            </p>
            <p>
              Because weight optimization was not a primary requirement, the team accepted a deliberately robust wall section instead of chasing a thinner part that would be harder to machine and more sensitive to chatter or setup variation.
            </p>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Final Design</div>
        <div class="grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
          <div class="copy-stack">
            <h2 class="section-title">A two-piece cylindrical assembly with a bored cavity, NPT port, O-ring groove, and four-bolt end cap.</h2>
            <p>
              The final pressure vessel was machined from 6061-T6 aluminum stock. Its compact symmetric geometry allowed the main body to remain close to the original stock diameter while still providing enough radial room for the 1.25 in internal cavity, 219 O-ring gland, and four M6-1 fasteners.
            </p>
            <p>
              A single 0.25 in NPT port was drilled and tapped at the top of the vessel for fluid entry. The end cap sits flush against the vessel body and is clamped by four bolts into threaded holes, compressing the O-ring between the central bore and fastener pattern.
            </p>
          </div>

          <div class="grid gap-5">
            <a class="image-panel" href={asset('projects/pressure-vessel/final-design-cad-photo.jpg')} target="_blank" rel="noreferrer">
              <img
                src={asset('projects/pressure-vessel/final-design-cad-photo.jpg')}
                alt="Final CAD model and manufactured pressure vessel"
                loading="lazy"
              />
            </a>
            <div class="grid gap-3 sm:grid-cols-2">
              {
                finalSpecs.map(([label, value]) => (
                  <div class="border border-white/10 bg-white/[0.035] p-4">
                    <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{label}</span>
                    <strong class="mt-2 block text-base font-bold text-slate-100">{value}</strong>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section id="analysis" class="section-shell border-t border-white/10">
        <div class="section-kicker">Engineering Analysis</div>
        <div class="mb-10 grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
          <h2 class="section-title">Hand calculations turned the geometry into a validated pressure boundary.</h2>
          <p class="max-w-2xl text-lg leading-8 text-slate-400">
            The analysis package covered the primary pressure stress mode, static seal sizing, and the bolted joint needed to keep the end cap clamped under internal pressure.
          </p>
        </div>

        <div class="grid gap-5 lg:grid-cols-3">
          <article class="analysis-card">
            <p class="analysis-letter">A</p>
            <h3>Pressure Vessel Stress Analysis</h3>
            <p>
              Thin-wall pressure vessel theory was used as a conservative screening calculation with P = 750 psi, inner radius ri = 0.625 in, and wall thickness t = 0.625 in.
            </p>
            <div class="calc-box">
              <span>Hoop stress</span>
              <strong>sigma = P*r/t = 750 psi</strong>
            </div>
            <p>
              With 6061-T6 aluminum yield strength of 40,000 psi and ultimate strength of 50,000 psi, the resulting factors of safety were approximately 53.3 against yield and 66.7 against ultimate failure. The wall was intentionally overdesigned because the theoretical minimum thickness of roughly 0.012 in would be impractical for stable machining.
            </p>
          </article>

          <article class="analysis-card">
            <p class="analysis-letter">B</p>
            <h3>O-Ring Design</h3>
            <p>
              The sealing system was sized using Parker radial seal guidance for a 219 silicone O-ring. The original 1/16 in O-ring concept was replaced after reviewing manufacturability and sealing risk with the machine shop.
            </p>
            <div class="calc-box">
              <span>Final gland</span>
              <strong>d = 0.112 in, w = 0.187 in</strong>
            </div>
            <p>
              The selected groove used a 1.285 in gland ID and 1.659 in gland OD. Checks confirmed the O-ring ID fit target, cross-section exceeded gland depth, compression ratio was 19.4 percent, and gland fill was calculated at 72.5 percent.
            </p>
          </article>

          <article class="analysis-card">
            <p class="analysis-letter">C</p>
            <h3>Fastener Analysis</h3>
            <p>
              The four M6-1 bolts resist the separating force produced by the internal pressure acting over the effective circular area of the vessel ends.
            </p>
            <div class="calc-box">
              <span>Separating force</span>
              <strong>920.38 lbf total, 1.024 kN per bolt</strong>
            </div>
            <p>
              The bolted joint model included fastener stiffness, member stiffness, stiffness ratio, preload, and torque. The final values included C = 0.0906, target preload at 90 percent proof load, torque of 18.75 N*m, proof FOS of 1.105, separation FOS of 16.8, and overload FOS of 18.7.
            </p>
          </article>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <div class="section-kicker">Manufacturing</div>
            <h2 class="section-title">The final geometry reduced machining risk without compromising safety.</h2>
          </div>
          <div class="copy-stack">
            <p>
              The cylindrical body was designed around straightforward manual lathe and mill operations. The stock diameter could be retained for the outer vessel surface, while the internal cavity was bored to the required 1.25 in diameter and depth.
            </p>
            <p>
              Milling operations focused on the bolt pattern and the O-ring groove. Threaded holes were placed symmetrically for four M6-1 bolts, and the O-ring gland was machined between the bore and the fastener circle to create a flat, repeatable sealing interface.
            </p>
            <p>
              Simplifying the body from the earlier flange design removed unnecessary turning operations and reduced setup time. The final design prioritized reliable shop execution, repeatable assembly, and a sealing surface that could be inspected and validated before pressure testing.
            </p>
          </div>
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="rounded-none border border-cyan-300/30 bg-cyan-300/[0.06] p-8 sm:p-10 lg:p-12">
          <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
            <div>
              <div class="section-kicker">Results</div>
              <h2 class="section-title">The vessel passed the 750 psi pressure test without leakage.</h2>
            </div>
            <div class="copy-stack">
              <p>
                Physical testing validated the analysis assumptions and confirmed that the manufactured vessel met the project requirements for capacity, pressure containment, manufacturability, and assembly.
              </p>
              <p>
                The final vessel successfully contained pressurized water at 750 psi with no observed leakage. That result confirmed the combined performance of the cylindrical pressure boundary, O-ring groove, end cap, threaded port, and four-bolt closure.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="gallery" class="section-shell border-t border-white/10">
        <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <div class="section-kicker">Image Gallery</div>
            <h2 class="section-title max-w-3xl">Extracted report visuals from CAD, machining, assembly, and as-built documentation.</h2>
          </div>
          <p class="max-w-lg text-base leading-7 text-slate-400">
            Click any image to open the extracted asset at full size.
          </p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {
            gallery.map((image) => (
              <figure class="gallery-card">
                <a href={asset(image.src)} target="_blank" rel="noreferrer">
                  <img src={asset(image.src)} alt={image.alt} loading="lazy" />
                </a>
                <figcaption>{image.caption}</figcaption>
              </figure>
            ))
          }
        </div>
      </section>

      <section class="section-shell border-t border-white/10">
        <div class="section-kicker">Key Takeaways</div>
        <div class="grid gap-5 md:grid-cols-2">
          <article class="takeaway-card">
            <h3>Manufacturability is a design constraint, not a downstream detail.</h3>
            <p>
              The best-performing concept was not the most complex one. Simplifying the body geometry made the vessel easier to machine, inspect, assemble, and test.
            </p>
          </article>
          <article class="takeaway-card">
            <h3>Sealing systems deserve the same rigor as stress calculations.</h3>
            <p>
              The O-ring choice and gland geometry were central to the final result. A pressure boundary only works if the closure and seal remain reliable under load.
            </p>
          </article>
          <article class="takeaway-card">
            <h3>Overdesign can be rational when machining stability matters.</h3>
            <p>
              The 0.625 in wall thickness produced high analytical safety factors, but it also made the part more practical to manufacture without chatter or fragile sections.
            </p>
          </article>
          <article class="takeaway-card">
            <h3>Experimental validation closes the loop.</h3>
            <p>
              Hand calculations gave confidence before fabrication, but the 750 psi no-leak pressure test confirmed that the physical assembly met the intent of the design.
            </p>
          </article>
        </div>
      </section>

      <footer class="border-t border-white/10 px-6 py-8 text-sm text-slate-500 sm:px-10 lg:px-16">
        <div class="mx-auto flex max-w-7xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <span>&copy; 2026 Rohan Joshi</span>
          <div class="flex gap-5 font-bold text-slate-300">
            <a class="transition hover:text-cyan-300" href="mailto:rohan.joshi@duke.edu">Email</a>
            <a class="transition hover:text-cyan-300" href="https://github.com/RohanJoshi3">GitHub</a>
            <a class="transition hover:text-cyan-300" href="https://www.linkedin.com/in/rohanjoshi2/">LinkedIn</a>
          </div>
        </div>
      </footer>
    </main>
  </body>
</html>

<style>
  :global(body.pv-body) {
    min-width: 320px;
    background: #05070a;
    color: #f8fafc;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  :global(body.pv-body::before) {
    display: none;
  }

  :global(body.pv-body *) {
    letter-spacing: 0;
  }

  .pv-nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 24px;
    pointer-events: none;
  }

  .pv-brand,
  .pv-nav nav {
    pointer-events: auto;
  }

  .pv-brand {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(5, 7, 10, 0.72);
    color: #fff;
    font-weight: 900;
    backdrop-filter: blur(18px);
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background 180ms ease;
  }

  .pv-brand:hover,
  .pv-brand:focus-visible {
    border-color: rgba(103, 232, 249, 0.8);
    background: rgba(8, 47, 73, 0.72);
    color: #67e8f9;
  }

  .pv-nav nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(5, 7, 10, 0.7);
    padding: 8px;
    backdrop-filter: blur(18px);
  }

  .pv-nav nav a {
    padding: 8px 10px;
    color: #cbd5e1;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    transition:
      color 180ms ease,
      background 180ms ease;
  }

  .pv-nav nav a:hover,
  .pv-nav nav a:focus-visible {
    background: rgba(103, 232, 249, 0.1);
    color: #67e8f9;
  }

  .section-shell {
    padding: 96px 24px;
  }

  .section-shell > * {
    max-width: 1280px;
    margin-right: auto;
    margin-left: auto;
  }

  .section-kicker {
    margin-bottom: 18px;
    color: #67e8f9;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .section-title {
    margin: 0;
    color: #fff;
    font-size: clamp(2.25rem, 4.4vw, 4.8rem);
    font-weight: 900;
    line-height: 0.96;
  }

  .copy-stack {
    display: grid;
    gap: 18px;
  }

  .copy-stack p,
  .analysis-card p,
  .takeaway-card p,
  .gallery-card figcaption {
    margin: 0;
    color: #94a3b8;
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .image-panel {
    display: block;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
  }

  .image-panel img {
    display: block;
    width: 100%;
    height: auto;
    transition:
      transform 260ms ease,
      filter 260ms ease;
  }

  .image-panel:hover img,
  .image-panel:focus-visible img {
    transform: scale(1.025);
    filter: contrast(1.05);
  }

  .analysis-card,
  .takeaway-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025)),
      #070b11;
    padding: 28px;
  }

  .analysis-card {
    display: grid;
    gap: 18px;
  }

  .analysis-card h3,
  .takeaway-card h3 {
    margin: 0;
    color: #fff;
    font-size: 1.45rem;
    font-weight: 900;
    line-height: 1.15;
  }

  .analysis-letter {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid rgba(103, 232, 249, 0.45);
    color: #67e8f9 !important;
    font-size: 0.95rem !important;
    font-weight: 900;
    line-height: 1 !important;
  }

